{
    "name": "mb_onig/mb_onig",
    "type": "php-ext",
    "license": "BSD-3-Clause",
    "description": "Oniguruma maintenance end for replace to mbregex (experimental)",
    "require": {
        "php": "^8.3",
        "ext-mbstring": "*"
    },
    "support": {
        "source": "https://github.com/youkidearitai/mb_onig",
        "issues": "https://github.com/youkidearitai/mb_onig/issues"
    },
    "php-ext": {
        "extension-name": "mb_onig",
        "configure-options": [
            {
                "name": "enable-mb_onig",
                "needs-value": false,
                "description": "whether to enable mb_onig support"
            }
        ]
    }
}
